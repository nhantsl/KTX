<% if (typeof flash !== "undefined" && flash) { %>
    <div class="bg-yellow-100 text-yellow-800 p-3 rounded mb-4"><%= flash %></div>
<% } %>

<div class="mb-6">
    <div class="flex justify-between items-center">
        <h1 class="text-xl md:text-2xl font-bold"><%= title %></h1>
        <button onclick="document.getElementById('admin-menu').classList.toggle('hidden')"
                class="md:hidden border rounded px-3 py-1.5 text-sm">
            Menu
        </button>
        <div class="hidden md:flex space-x-4 text-sm">
            <a href="/admin/dashboard" class="<%= active === 'dashboard' ? 'text-blue-600 font-semibold' : 'text-gray-600' %>">Dashboard</a>
            <a href="/admin/yeu-cau" class="<%= active === 'yeu-cau' ? 'text-blue-600 font-semibold' : 'text-gray-600' %>">Yêu cầu</a>
            <a href="/admin/phong" class="<%= active === 'phong' ? 'text-blue-600 font-semibold' : 'text-gray-600' %>">Phòng</a>
            <a href="/admin/them-sinh-vien" class="<%= active === 'them' ? 'text-blue-600 font-semibold' : 'text-gray-600' %>">+ Thêm sinh viên</a>
            <a href="/admin/logout" class="text-red-600">Đăng xuất</a>
        </div>
    </div>

    <div id="admin-menu" class="md:hidden flex justify-between gap-2 mt-3 pt-3 text-sm">
        <a href="/admin/dashboard" class="<%= active === 'dashboard' ? 'text-blue-600 font-semibold' : 'text-gray-600' %> py-1">Dashboard</a>
        <a href="/admin/yeu-cau" class="<%= active === 'yeu-cau' ? 'text-blue-600 font-semibold' : 'text-gray-600' %> py-1">Yêu cầu</a>
        <a href="/admin/phong" class="<%= active === 'phong' ? 'text-blue-600 font-semibold' : 'text-gray-600' %> py-1">Phòng</a>
        <a href="/admin/them-sinh-vien" class="<%= active === 'them' ? 'text-blue-600 font-semibold' : 'text-gray-600' %> py-1">+ Thêm sinh viên</a>
        <a href="/admin/logout" class="text-red-600 py-1">Đăng xuất</a>
    </div>
</div>  