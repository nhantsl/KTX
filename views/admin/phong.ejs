<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <title>Quản lý phòng</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/css/output.css">
</head>
<body class="bg-gray-50">
    <div class="max-w-5xl mx-auto mt-10 p-6">
        <%- include('partials/nav', { title: 'Quản lý phòng', active: 'phong' }) %>

        <% 
        const grouped = {};
        rooms.forEach(r => {
            if (!grouped[r.building_name]) grouped[r.building_name] = [];
            grouped[r.building_name].push(r);
        });
        %>

        <% Object.keys(grouped).forEach(buildingName => { %>
            <h2 class="text-lg font-semibold mt-6 mb-3">Tòa <%= buildingName %></h2>
            <div class="grid grid-cols-2 md:grid-cols-5 gap-4">
                <% grouped[buildingName].forEach(r => { %>
                    <a href="/admin/phong/<%= r.id %>" class="block bg-white p-4 rounded shadow text-center hover:bg-gray-100">
                        <p class="text-xl font-bold"><%= r.room %></p>
                        <p class="text-sm <%= r.current_count >= r.capacity ? 'text-red-600' : 'text-green-600' %>">
                            <%= r.current_count %>/<%= r.capacity %>
                        </p>
                    </a>
                <% }) %>
            </div>
        <% }) %>
    </div>
</body>
</html>