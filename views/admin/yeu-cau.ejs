<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <title>Quản lý yêu cầu</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-50">
    <div class="max-w-6xl mx-auto mt-10 p-6">
        <% if (typeof flash !== "undefined" && flash) { %>
            <div class="bg-yellow-100 text-yellow-800 p-3 rounded mb-4">
                <%= flash %>
            </div>
        <% } %>
        <!-- <div class="flex justify-between items-center mb-6">
            <h1 class="text-2xl font-bold">Quản lý yêu cầu</h1>
            <div class="space-x-4">
                <a href="/admin/dashboard" class="text-blue-600">Dashboard</a>
                <a href="/admin/phong" class="text-blue-600">Phòng</a>
                <a href="/admin/logout" class="text-red-600">Đăng xuất</a>
            </div>
        </div> -->
        <%- include('partials/nav', { title: 'Quản lý yêu cầu', active: 'yeu-cau' }) %>

        <div class="bg-white rounded shadow overflow-x-auto">
            <table class="w-full text-sm">
                <thead class="bg-gray-100">
                    <tr>
                        <th class="p-3 text-left">Họ tên</th>
                        <th class="p-3 text-left">SĐT</th>
                        <th class="p-3 text-left">Giới tính</th>
                        <th class="p-3 text-left">Ngày gửi</th>
                        <th class="p-3 text-left">Trạng thái</th>
                        <th class="p-3 text-left">Phòng</th>
                        <th class="p-3 text-left">Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    <% registrations.forEach(r => { %>
                        <tr class="border-t">
                            <td class="p-3"><%= r.full_name %></td>
                            <td class="p-3"><%= r.phone %></td>
                            <td class="p-3"><%= r.gender === 'male' ? 'Nam' : 'Nữ' %></td>
                            <td class="p-3"><%= new Date(r.created_at).toLocaleDateString('vi-VN') %></td>
                            <td class="p-3">
                                <% if (r.status === 'pending') { %>
                                    <span class="text-yellow-600">Đang chờ</span>
                                <% } else if (r.status === 'approved') { %>
                                    <span class="text-green-600">Đã duyệt</span>
                                <% } else { %>
                                    <span class="text-red-600">Đã từ chối</span>
                                <% } %>
                            </td>
                            <td class="p-3">
                                <% if (r.room_number) { %>
                                    <%= r.building_name %> - <%= r.room_number %>
                                <% } else { %>
                                    —
                                <% } %>
                            </td>
                            <td class="p-3">
                                <% if (r.status === 'pending') { %>
                                    <form method="POST" action="/admin/yeu-cau/<%= r.id %>/duyet" class="flex gap-2 items-center">
                                        <select name="room_id" required class="border rounded px-2 py-1 text-xs">
                                            <option value="">-- Chọn phòng --</option>
                                            <% buildings.forEach(b => { %>
                                                <% if ( b.name === (r.gender === 'male' ? 'Nam' : 'Nữ')) { %>
                                                    <optgroup label="<%= b.name %>">
                                                        <% roomsByBuilding[b.id].forEach(rm => { %>
                                                            <% if (rm.current_count < rm.capacity) { %>
                                                                <option value="<%= rm.id %>">
                                                                    <%= rm.room_number %> (<%= rm.current_count %>/<%= rm.capacity %>)
                                                                </option>
                                                            <% } %>
                                                        <% }) %>
                                                    </optgroup>
                                                <% } %>
                                            <% }) %>
                                        </select>
                                        <button type="submit" class="bg-green-600 text-white px-3 py-1 rounded text-xs">Duyệt</button>
                                    </form>
                                    <form method="POST" action="/admin/yeu-cau/<%= r.id %>/tu-choi" class="mt-1">
                                        <button type="submit" class="bg-red-600 text-white px-3 py-1 rounded text-xs">Từ chối</button>
                                    </form>
                                <% } else { %>
                                    —
                                <% } %>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </div>
</body>
</html>