<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <title>Chi tiết phòng</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-50">
    <div class="max-w-2xl mx-auto mt-10 p-6">
        <div class="flex justify-between items-center mb-6">
            <h1 class="text-2xl font-bold">Danh sách người ở phòng</h1>
            <a href="/admin/phong" class="text-blue-600">← Quay lại</a>
        </div>

        <div class="bg-white rounded shadow">
            <% if (occupants.length === 0) { %>
                <p class="p-4 text-gray-500">Chưa có ai ở phòng này.</p>
            <% } else { %>
                <table class="w-full text-sm">
                    <thead class="bg-gray-100">
                        <tr>
                            <th class="p-3 text-left">Họ tên</th>
                            <th class="p-3 text-left">SĐT</th>
                            <th class="p-3 text-left">Giới tính</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% occupants.forEach(o => { %>
                            <tr class="border-t">
                                <td class="p-3"><%= o.full_name %></td>
                                <td class="p-3"><%= o.phone %></td>
                                <td class="p-3"><%= o.gender === 'male' ? 'Nam' : 'Nữ' %></td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            <% } %>
        </div>
    </div>
</body>
</html>