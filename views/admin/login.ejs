<!DOCTYPE html>
<html lang="vi">
<head><meta charset="UTF-8"><title>Admin Login</title><script src="https://cdn.tailwindcss.com"></script></head>
<body class="bg-gray-100">
    <div class="max-w-sm mx-auto mt-20 p-6 bg-white rounded-lg shadow">
        <h1 class="text-xl font-bold mb-4">Đăng nhập Admin</h1>
        <% if (error) { %>
            <p class="text-red-600 mb-4"><%= error %></p>
        <% } %>
        <form method="POST" action="/admin/login" class="space-y-4">
            <div>
                <label class="block mb-1">Tên đăng nhập</label>
                <input type="text" name="username" required class="w-full border rounded px-3 py-2">
            </div>
            <div>
                <label class="block mb-1">Mật khẩu</label>
                <input type="password" name="password" required class="w-full border rounded px-3 py-2">
            </div>
            <button type="submit" class="w-full bg-blue-600 text-white py-2 rounded hover:bg-blue-700">
                Đăng nhập
            </button>
        </form>
    </div>
</body>
</html>